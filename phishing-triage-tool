#!/usr/bin/env python3
"""
analyze_email.py

A lightweight phishing-triage helper for SOC / help-desk analysts.

Given a raw .eml file, this script parses key header fields and applies a
small set of heuristics commonly used during first-pass phishing triage:

  * Sender authentication results (SPF / DKIM / DMARC)
  * From / Reply-To / Return-Path domain alignment
  * Urgency / social-engineering language in the subject and body
  * Embedded links that try to impersonate the organization's brand

It is intentionally simple and transparent: every flag it raises is
explainable, which matters more in an analyst report than a black-box
score. Output is a structured finding list plus an overall risk rating.

Usage:
    python3 analyze_email.py sample_email_1_phishing.eml
    python3 analyze_email.py *.eml
"""

import sys
import re
from email import policy
from email.parser import BytesParser
from urllib.parse import urlparse

URGENCY_PHRASES = [
    "urgent", "immediately", "24 hours", "act now", "suspended",
    "verify your account", "failure to act", "expire", "final notice",
    "unauthorized", "click here",
]

# In production these would come from a config file / allow-list rather
# than being hard-coded.
TRUSTED_DOMAIN = "northwindtraders.example"
BRAND_KEYWORD = "northwind"  # used to catch look-alike domains


def get_domain(address: str) -> str:
    """Return the domain portion of an email address, lowercased."""
    if not address or "@" not in address:
        return ""
    return address.strip().rsplit("@", 1)[-1].strip("> ").lower()


def parse_auth_results(header_value: str) -> dict:
    """Pull spf / dkim / dmarc verdicts out of an Authentication-Results header."""
    results = {}
    for mech in ("spf", "dkim", "dmarc"):
        match = re.search(rf"{mech}=(\w+)", header_value or "", re.IGNORECASE)
        results[mech] = match.group(1).lower() if match else "unknown"
    return results


def extract_urls(text: str) -> list:
    return re.findall(r"https?://[^\s)>\]]+", text or "")


def analyze(eml_path: str) -> dict:
    with open(eml_path, "rb") as f:
        msg = BytesParser(policy=policy.default).parse(f)

    findings = []
    score = 0

    from_addr = msg.get("From", "")
    reply_to = msg.get("Reply-To", "")
    return_path = msg.get("Return-Path", "")
    subject = msg.get("Subject", "")
    auth_header = msg.get("Authentication-Results", "")

    from_domain = get_domain(from_addr)
    reply_domain = get_domain(reply_to) if reply_to else from_domain
    return_domain = get_domain(return_path) if return_path else from_domain

    auth = parse_auth_results(auth_header)
    for mech in ("spf", "dkim", "dmarc"):
        if auth[mech] in ("fail", "softfail"):
            findings.append(f"{mech.upper()} check returned '{auth[mech]}'")
            score += 2 if auth[mech] == "fail" else 1

    if reply_to and reply_domain != from_domain:
        findings.append(
            f"Reply-To domain ({reply_domain}) does not match From domain ({from_domain})"
        )
        score += 2

    if return_path and return_domain != from_domain:
        findings.append(
            f"Return-Path domain ({return_domain}) does not match From domain ({from_domain})"
        )
        score += 1

    if from_domain and from_domain != TRUSTED_DOMAIN:
        findings.append(
            f"Sending domain '{from_domain}' is not the organization's verified domain"
        )
        score += 2

    body = ""
    if msg.is_multipart():
        for part in msg.walk():
            if part.get_content_type() == "text/plain":
                body += part.get_content()
    else:
        body = msg.get_content()

    full_text = f"{subject}\n{body}".lower()
    matched_phrases = [p for p in URGENCY_PHRASES if p in full_text]
    if matched_phrases:
        findings.append(
            f"Urgency / social-engineering language detected: {', '.join(matched_phrases)}"
        )
        score += len(matched_phrases)

    urls = extract_urls(body)
    suspicious_urls = []
    for url in urls:
        netloc = urlparse(url).netloc.lower()
        if BRAND_KEYWORD in netloc and not netloc.endswith(TRUSTED_DOMAIN):
            suspicious_urls.append(url)
            score += 3
    if suspicious_urls:
        findings.append(f"Link(s) impersonating the organization's brand: {suspicious_urls}")

    if score >= 6:
        risk = "High"
    elif score >= 3:
        risk = "Medium"
    else:
        risk = "Low"

    return {
        "file": eml_path,
        "subject": subject,
        "from": from_addr,
        "reply_to": reply_to or "(none)",
        "return_path": return_path or "(none)",
        "auth_results": auth,
        "urls": urls,
        "findings": findings,
        "score": score,
        "risk": risk,
    }


def print_report(result: dict) -> None:
    print("=" * 70)
    print(f"FILE:        {result['file']}")
    print(f"SUBJECT:     {result['subject']}")
    print(f"FROM:        {result['from']}")
    print(f"REPLY-TO:    {result['reply_to']}")
    print(f"RETURN-PATH: {result['return_path']}")
    print(f"AUTH:        SPF={result['auth_results']['spf']}  "
          f"DKIM={result['auth_results']['dkim']}  DMARC={result['auth_results']['dmarc']}")
    print(f"LINKS:       {result['urls'] or '(none found)'}")
    print(f"RISK:        {result['risk']}  (score={result['score']})")
    if result["findings"]:
        print("FINDINGS:")
        for f in result["findings"]:
            print(f"  - {f}")
    else:
        print("FINDINGS:    No indicators detected.")
    print()


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python3 analyze_email.py <file1.eml> [file2.eml ...]")
        sys.exit(1)

    for path in sys.argv[1:]:
        print_report(analyze(path))

# Phishing Email Triage Lab

## Overview
A Python tool that performs first-pass phishing triage on raw `.eml` files,
the same task a SOC Tier-1 analyst or help-desk technician does dozens of
times a week when a user reports a suspicious email. It checks sender
authentication (SPF/DKIM/DMARC), header alignment (From / Reply-To /
Return-Path), social-engineering language, and look-alike links, then
produces a structured finding list and a risk rating.

## Files
- `analyze_email.py` — the triage tool
- `sample_email_1_phishing.eml` — fake IT password-reset lure
- `sample_email_2_phishing.eml` — fake overdue-invoice / BEC-style lure
- `sample_email_3_legitimate.eml` — a clean internal email, for contrast

All three are synthetic samples built for this lab (fictional company,
`.example` domains per RFC 2606 so nothing resolves to a real address).

## How to run it
```
python3 analyze_email.py sample_email_1_phishing.eml sample_email_2_phishing.eml sample_email_3_legitimate.eml
```

